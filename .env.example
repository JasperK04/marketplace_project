FLASK_ENV=development

# Required in production
SECRET_KEY=change-me-to-something-super-secure

# Optional overrides (production defaults to sqlite app.db)
# SQLALCHEMY_DATABASE_URI=sqlite:////absolute/path/to/app.db

# Optional upload paths (defaults to app/static/assets/images/user_uploaded)
# UPLOAD_FOLDER=/absolute/path/to/uploads
# RESIZED_FOLDER=/absolute/path/to/resized
